DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASS=your_db_password
REVISION_BUNDLES_DIR=/path/to/revision/bundles

# Optional tuning for build_all → build_db inner pipeline
# Number of parser processes per build_db job (CPU-bound stage)
PARSE_PROCS=4
# Number of writer processes per build_db job (DB-bound stage). Keep small (1–2)
WRITE_PROCS=1
# Revisions per parsed batch sent from parsers to writers
BATCH_SIZE=1000
# Max number of parsed batches buffered between stages (backpressure)
QUEUE_MAX=32
# Seconds between periodic metrics prints
METRICS_INTERVAL=5
# Enable per-transaction DB load-time tuning in writers (0=off, 1=on)
TUNE_DB=0
