DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASS=your_db_password
REVISION_BUNDLES_DIR=/path/to/revision/bundles

# ── Phase 1: build_all / build_db (CPU-bound derive & stage to files) ──
# Directory for staged JSONL.zst files (written by build_db, loaded by load_all)
STAGING_DIR=./staging
# Number of parser processes per build_db job (CPU-bound; scale to available cores)
PARSE_PROCS=4
# Number of staging-writer processes per build_db job (I/O-bound; 1–2 is usually enough)
WRITE_PROCS=1
# Revisions per parsed batch sent from parsers to writers
BATCH_SIZE=1000
# Max number of parsed batches buffered between stages (backpressure)
QUEUE_MAX=32
# Seconds between periodic metrics prints
METRICS_INTERVAL=5

# ── Phase 2: load_all (DB-bound bulk insert from staged files) ──
# Rows per INSERT batch when loading staged data into Postgres
LOAD_BATCH_SIZE=5000
