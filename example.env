DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASS=your_db_password
REVISION_BUNDLES_DIR=/path/to/revision/bundles

# ── Phase 1: build_all / build_db (CPU-bound derive & stage to files) ──
# Directory for staged JSONL.zst files (written by build_db, loaded by load_all)
STAGING_DIR=./staging
# Revisions per batch processed by each build_db worker
BATCH_SIZE=1000
# Seconds between status updates from build_all
METRICS_INTERVAL=10

# ── Phase 2: load_all (DB-bound bulk insert from staged files) ──
# Rows per INSERT batch when loading staged data into Postgres
LOAD_BATCH_SIZE=5000
