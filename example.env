DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASS=your_db_password
REVISION_BUNDLES_DIR=/path/to/revision/bundles

# ── Phase 1: build_all / build_db (CPU-bound extract & stage to Parquet) ──
# Directory for staged Parquet files (written by build_db, deduped by dedup_parquet, loaded by load_all)
STAGING_DIR=./staging
# Revisions per batch processed by each build_db worker
BATCH_SIZE=1000
# Seconds between status updates from build_all
METRICS_INTERVAL=10

# ── Phase 1.5: dedup_parquet (consolidate & deduplicate staged files via DuckDB) ──
# No additional configuration needed — DuckDB manages memory and spill automatically.
# Override memory limit or temp directory via dedup_parquet.py CLI flags if needed.

# ── Phase 2: load_all (DB-bound bulk insert from deduped Parquet files) ──
# Rows per INSERT batch when loading staged data into Postgres
LOAD_BATCH_SIZE=5000

# ── Explorer Wikipedia API requests (title URL -> curid resolution) ──
# Primary product token for MediaWiki API User-Agent
WIKIPEDIA_API_USER_AGENT=WikiReferencesDB/1.0
# Contact email appended in parentheses to the User-Agent
WIKIPEDIA_API_CONTACT_EMAIL=your-email@example.com
# Optional secondary token appended to the User-Agent
WIKIPEDIA_API_SECONDARY_USER_AGENT=
